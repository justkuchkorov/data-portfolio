---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const SITE_TITLE = "abdi | electrical engineer";
const SITE_DESCRIPTION = "portfolio of abdi, an electrical engineering student specializing in ipc.";

const projects = [
	{
		title: "ipc flow optimization",
		description: "designed and implemented efficient inter-process communication mechanisms for a real-time embedded system, reducing latency by 40%.",
		tags: ["c++", "rtos", "ipc"],
		link: "#"
	},
	{
		title: "iot sensor node design",
		description: "developed a low-power wireless sensor node for industrial monitoring, from pcb schematics to firmware.",
		tags: ["pcb design", "spi/i2c", "eagle"],
		link: "#"
	},
	{
		title: "hardware interfacing prototype",
		description: "built a robust hardware interface between an fpga and a microcontroller unit using custom data protocols.",
		tags: ["vhdl", "fpga", "uart"],
		link: "#"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="">
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 class="glitch" data-text="hi, i am abdi.">hi, i am abdi.</h1>
					<h2>electrical/automation engineer @ unideb</h2>
					<p>building automation projects for the industry.</p>
					<div class="hero-actions">
						<a href="#projects" class="btn primary">my projects</a>
						<a href="mailto:contact@example.com" class="btn secondary">get in touch</a>
					</div>
				</div>
			</section>

			<section id="projects" class="projects-section">
				<h3 class="section-title">featured projects</h3>
				<div class="projects-grid">
					{projects.map((project) => (
						<div class="project-card">
							<div class="card-content">
								<h4>{project.title}</h4>
								<p>{project.description}</p>
								<div class="tags">
									{project.tags.map(tag => <span class="tag">{tag}</span>)}
								</div>
							</div>
							<div class="card-action">
								<a href={project.link} class="view-project">case study <span class="arrow">→</span></a>
							</div>
						</div>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Global Smooth Scrolling and Transitions */
	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body), :global(body *) {
		transition: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
	}

	/* CSS Variables defined for Light Mode (default) */
	:global(body) {
		--bg-color: #ffffff;
		--text-main: #1a202c;
		--text-muted: #4a5568;
		--accent-glow: #2563eb; /* darker blue for light mode readability */
		--accent-dark: #1e3a8a;
		--card-bg: #ffffff;
		--card-border: #e2e8f0;
	}

	/* Dark Mode Overrides */
	:global(body.dark-theme) {
		--bg-color: #0f1115;
		--text-main: #e2e8f0;
		--text-muted: #94a3b8;
		--accent-glow: #3b82f6; /* brighter blue for dark mode glow */
		--accent-dark: #1e3a8a;
		--card-bg: rgba(30, 41, 59, 0.7);
		--card-border: rgba(255, 255, 255, 0.1);
		
		background: var(--bg-color);
		color: var(--text-main);
	}

	:global(.dark-theme header) {
		background: rgba(15, 17, 21, 0.8) !important;
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--card-border);
		box-shadow: none !important;
	}
	
	:global(.dark-theme nav a) {
		color: var(--text-main) !important;
	}

	:global(.dark-theme footer) {
		color: var(--text-muted) !important;
		background: var(--bg-color) !important;
	}

	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	/* Hero Section */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		min-height: 50vh;
		margin-bottom: 6rem;
		position: relative;
	}

	.hero-content {
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero h1 {
		font-size: 4.5rem;
		font-weight: 800;
		color: #1a202c; /* Ensure explicit dark gray text in light mode */
		margin-bottom: 0.5rem;
		line-height: 1.1;
	}

	:global(body.dark-theme) .hero h1 {
		color: #ffffff;
		background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero h2 {
		font-size: 1.8rem;
		color: #3b82f6;
		font-weight: 600;
		margin-bottom: 1.5rem;
	}

	.hero p {
		font-size: 1.2rem;
		color: #4a5568 !important; /* Force explicit legibility in light mode */
		max-width: 600px;
		line-height: 1.6;
		margin-bottom: 2.5rem;
	}

	:global(body.dark-theme) .hero p {
		color: var(--text-muted) !important;
	}

	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	.btn {
		padding: 0.8rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		font-size: 1rem;
	}

	.btn.primary {
		background: var(--accent-glow);
		color: #ffffff; /* Must explicitly be white in both modes to contrast the blue bubble */
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
	}

	.btn.primary:hover {
		background: #1d4ed8;
		box-shadow: 0 0 30px rgba(59, 130, 246, 0.6);
		transform: translateY(-2px);
		color: #ffffff;
	}

	.btn.secondary {
		background: transparent;
		color: #1a202c; /* Light mode text */
		border: 1px solid #cbd5e1;
	}

	:global(body.dark-theme) .btn.secondary {
		color: var(--text-main);
		border-color: var(--card-border);
	}

	.btn.secondary:hover {
		background: rgba(0,0,0,0.05);
		transform: translateY(-2px);
	}

	:global(body.dark-theme) .btn.secondary:hover {
		background: rgba(255,255,255,0.05);
	}



	/* Projects Section */
	.projects-section {
		margin-top: 4rem;
	}

	.section-title {
		font-size: 2rem;
		color: #1a202c; /* light mode */
		margin-bottom: 2rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	:global(body.dark-theme) .section-title {
		color: #fff;
	}

	.section-title::after {
		content: "";
		height: 1px;
		flex: 1;
		background: linear-gradient(90deg, #e2e8f0, transparent);
	}

	:global(body.dark-theme) .section-title::after {
		background: linear-gradient(90deg, var(--card-border), transparent);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.project-card {
		background: #ffffff; /* Light mode base */
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	:global(body.dark-theme) .project-card {
		background: var(--card-bg);
		border-color: var(--card-border);
		backdrop-filter: blur(10px);
	}

	.project-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: linear-gradient(90deg, #3b82f6, #8b5cf6);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.project-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
		border-color: rgba(59, 130, 246, 0.3);
	}

	:global(body.dark-theme) .project-card:hover {
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
	}

	.project-card:hover::before {
		opacity: 1;
	}

	.project-card h4 {
		font-size: 1.4rem;
		color: #1d4ed8; /* distinct blue for project headers in light mode */
		margin-bottom: 1rem;
	}
	
	:global(body.dark-theme) .project-card h4 {
		color: #fff;
	}

	.project-card p {
		color: #334155; /* explicit dark color for readability */
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
	}

	:global(body.dark-theme) .project-card p {
		color: var(--text-muted);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.tag {
		background: rgba(59, 130, 246, 0.1);
		color: #93c5fd;
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.8rem;
		font-weight: 500;
		border: 1px solid rgba(59, 130, 246, 0.2);
	}

	.card-action {
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid #e2e8f0;
	}

	:global(body.dark-theme) .card-action {
		border-top-color: var(--card-border);
	}

	.view-project {
		color: #1e293b; /* Light mode interaction */
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		display: inline-flex;
		align-items: center;
		transition: color 0.3s ease;
	}

	:global(body.dark-theme) .view-project {
		color: #fff;
	}

	.view-project .arrow {
		margin-left: 0.5rem;
		transition: transform 0.3s ease;
	}

	.view-project:hover {
		color: var(--accent-glow);
	}

	.view-project:hover .arrow {
		transform: translateX(5px);
	}

	@media (max-width: 768px) {
		.hero {
			flex-direction: column;
			text-align: center;
			margin-bottom: 3rem;
		}
		.hero-actions {
			justify-content: center;
		}
		.hero-graphic {
			display: none; /* Hide abstract graphic on mobile for simplicity */
		}
		.hero h1 {
			font-size: 3rem;
		}
	}
</style>
