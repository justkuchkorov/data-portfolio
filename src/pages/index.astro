---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Analytics from '@vercel/analytics/astro';
import ProfilePhoto from '../assets/myphoto.JPG';

const SITE_TITLE = "abdi | electrical engineer";
const SITE_DESCRIPTION = "portfolio of abdi, an electrical engineering student specializing in ipc.";

const projects = [
	{
		title: "Transformer Digital Twin",
		description: "Closed-loop thermal simulation to stress-test industrial PLC safety logic.",
		tags: ["digital twin", "plc", "simulation"],
		link: "/blog/transformer-digital-twin",
		github: "https://github.com/justkuchkorov/transformer_digital_twin"
	},
	{
		title: "Active Suspension HIL",
		description: "Quarter-car physics bridged to CODESYS SoftPLC over Modbus TCP/IP.",
		tags: ["plc", "python", "control systems"],
		link: "/blog/active-suspension",
		github: "https://github.com/justkuchkorov/active-suspension-hil"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<p class="hero-greeting" aria-label="hi, i am {abdi;}">
					<span id="typewriter"></span>
				</p>
				<h1>electrical & automation engineer</h1>
				<p class="hero-sub">Building HIL simulations and industrial control systems. Senior EE student at the University of Debrecen.</p>
				<div class="hero-actions">
					<a href="#projects" class="btn-primary">Projects</a>
					<a href="#contact" class="btn-outline">Contact</a>
				</div>
			</section>

			<!-- Featured Projects -->
			<section id="projects" class="section">
				<p class="section-label">Featured Projects</p>
				<div class="projects-list">
					{projects.map((project) => (
						<a href={project.link} class="project-row">
							<div class="project-info">
								<h3>{project.title}</h3>
								<p>{project.description}</p>
								<div class="tags">
									{project.tags.map(tag => <span class="tag">{tag}</span>)}
								</div>
							</div>
							<span class="project-arrow">&rarr;</span>
						</a>
					))}
				</div>
				<a href="/projects" class="see-all">All projects &rarr;</a>
			</section>

			<!-- Contact -->
			<section id="contact" class="section">
				<p class="section-label">Contact</p>
				<div class="contact-grid">
					<div class="contact-photo-wrap">
						<img src={ProfilePhoto.src} alt="Abdi" class="contact-photo" />
					</div>
					<div class="contact-links">
						<a href="/abdi_resume.pdf" target="_blank" class="contact-row">
							<span class="contact-key">Resume</span>
							<span class="contact-val">Download PDF</span>
							<span class="contact-arr">&rarr;</span>
						</a>
						<a href="mailto:abdurakhmonkuchkorov@gmail.com" class="contact-row">
							<span class="contact-key">Email</span>
							<span class="contact-val">abdurakhmonkuchkorov@gmail.com</span>
							<span class="contact-arr">&rarr;</span>
						</a>
						<a href="https://www.linkedin.com/in/justkuchkorov/" target="_blank" class="contact-row">
							<span class="contact-key">LinkedIn</span>
							<span class="contact-val">/in/justkuchkorov</span>
							<span class="contact-arr">&rarr;</span>
						</a>
						<a href="https://github.com/justkuchkorov" target="_blank" class="contact-row">
							<span class="contact-key">GitHub</span>
							<span class="contact-val">@justkuchkorov</span>
							<span class="contact-arr">&rarr;</span>
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<Analytics />
	</body>
</html>

<script>
	const tokens = [
		{ char: 'h' }, { char: 'i' }, { char: ',' }, { char: ' ' },
		{ char: 'i' }, { char: ' ' }, { char: 'a' }, { char: 'm' }, { char: ' ' },
		{ char: '{', class: 'brace' }, { char: 'a' }, { char: 'b' }, { char: 'd' }, { char: 'i' },
		{ char: ';', class: 'semi' }, { char: '}', class: 'brace' }
	];
	const target = document.getElementById('typewriter');
	let i = 0;
	function type() {
		if (target && i < tokens.length) {
			const t = tokens[i];
			if (t.class) {
				target.innerHTML += `<span class="${t.class}">${t.char}</span>`;
			} else {
				target.innerHTML += t.char;
			}
			i++;
			setTimeout(type, 55);
		}
	}
	setTimeout(type, 200);
</script>

<style>
	main {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: var(--space-16) var(--page-pad) var(--space-20);
	}

	/* Hero */
	.hero {
		padding: var(--space-20) 0 var(--space-16);
	}

	.hero-greeting {
		font-family: var(--mono);
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		color: var(--text);
		margin-bottom: var(--space-3);
		min-height: 1.4em;
	}

	:global(span.brace) {
		color: var(--accent);
	}

	:global(span.semi) {
		color: var(--text-muted);
	}

	.hero h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin-bottom: var(--space-4);
		max-width: 600px;
	}

	.hero-sub {
		font-size: 1.05rem;
		color: var(--text-muted);
		max-width: 520px;
		line-height: 1.7;
		margin-bottom: var(--space-8);
	}

	.hero-actions {
		display: flex;
		gap: var(--space-3);
	}

	.btn-primary, .btn-outline {
		display: inline-flex;
		align-items: center;
		padding: 0.6rem 1.25rem;
		font-size: 0.875rem;
		font-weight: 600;
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: all 150ms ease;
	}

	.btn-primary {
		background: var(--text);
		color: var(--bg);
	}

	.btn-primary:hover {
		background: var(--accent);
		color: #fff;
		text-decoration: none;
	}

	.btn-outline {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--line);
	}

	.btn-outline:hover {
		background: var(--surface-soft);
		text-decoration: none;
	}

	/* Sections */
	.section {
		padding: var(--space-12) 0;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 700;
		font-family: var(--mono);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		margin-bottom: var(--space-6);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--line);
	}

	/* Projects */
	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 1px;
		background: var(--line);
		border-radius: var(--radius-md);
		overflow: hidden;
		border: 1px solid var(--line);
	}

	.project-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		padding: var(--space-6);
		background: var(--surface);
		text-decoration: none;
		color: var(--text);
	}

	.project-row:hover {
		background: var(--surface-soft);
		text-decoration: none;
	}

	.project-info h3 {
		margin-bottom: var(--space-2);
	}

	.project-info p {
		margin-bottom: var(--space-3);
		font-size: 0.9rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.2rem 0.5rem;
		border-radius: var(--radius-pill);
		background: var(--accent-muted);
		color: var(--accent);
	}

	.project-arrow {
		font-size: 1.25rem;
		color: var(--text-muted);
		flex-shrink: 0;
		transition: transform 150ms ease;
	}

	.project-row:hover .project-arrow {
		transform: translateX(4px);
		color: var(--accent);
	}

	.see-all {
		display: inline-block;
		margin-top: var(--space-4);
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}

	.see-all:hover {
		text-decoration: underline;
	}

	/* Contact */
	.contact-grid {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: var(--space-8);
		align-items: start;
	}

	.contact-photo-wrap {
		position: sticky;
		top: calc(3.5rem + var(--space-6));
	}

	.contact-photo {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius-md);
		border: 1px solid var(--line);
	}

	.contact-links {
		display: flex;
		flex-direction: column;
		gap: 1px;
		background: var(--line);
		border-radius: var(--radius-md);
		overflow: hidden;
		border: 1px solid var(--line);
	}

	.contact-row {
		display: grid;
		grid-template-columns: 90px 1fr auto;
		gap: var(--space-3);
		align-items: center;
		padding: var(--space-4) var(--space-6);
		background: var(--surface);
		text-decoration: none;
		color: var(--text);
	}

	.contact-row:hover {
		background: var(--surface-soft);
		text-decoration: none;
	}

	.contact-key {
		font-family: var(--mono);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text);
	}

	.contact-val {
		font-size: 0.875rem;
		color: var(--text-muted);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.contact-arr {
		color: var(--text-muted);
		font-size: 0.9rem;
		transition: transform 150ms ease;
	}

	.contact-row:hover .contact-arr {
		transform: translateX(3px);
		color: var(--accent);
	}

	@media (max-width: 768px) {
		main {
			padding: var(--space-8) var(--page-pad) var(--space-12);
		}

		.hero {
			padding: var(--space-12) 0 var(--space-10);
		}

		.hero {
			text-align: center;
			align-items: center;
		}

		.hero h1 {
			max-width: 100%;
		}

		.hero-sub {
			max-width: 100%;
		}

		.hero-actions {
			flex-direction: column;
			gap: var(--space-2);
			width: 100%;
			max-width: 260px;
			margin: 0 auto;
		}

		.btn-primary, .btn-outline {
			text-align: center;
			justify-content: center;
			width: 100%;
		}

		.contact-grid {
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}

		.contact-photo-wrap {
			position: static;
			max-width: 140px;
		}

		.contact-row {
			grid-template-columns: 1fr auto;
			gap: var(--space-2);
		}

		.contact-key {
			grid-column: 1 / -1;
		}

		.contact-val {
			white-space: normal;
		}
	}
</style>
