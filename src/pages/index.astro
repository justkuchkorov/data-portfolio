---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Analytics from '@vercel/analytics/astro';

const SITE_TITLE = "abdi | electrical engineer";
const SITE_DESCRIPTION = "portfolio of abdi, an electrical engineering student specializing in ipc.";

const projects = [
	{
		title: "Transformer Digital Twin",
		description: "closed-loop thermal simulation to stress-test industrial PLC safety logic.",
		tags: ["digital twin", "plc", "simulation"],
		link: "/blog/transformer-digital-twin"
	},
	{
		title: "Active Suspension",
		description: "design and implementation of a robust industrial control loop for automated processes.",
		tags: ["plc", "python", "control systems"],
		link: "/blog/active-suspension"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="">
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 class="hero-title" aria-label="hi, i am {abdi;}">
						<span id="typewriter"></span>
					</h1>
					<h2>electrical/automation engineer @ unideb</h2>
					<p>building automation projects for the industry.</p>
					<div class="hero-actions">
						<a href="#projects" class="btn primary">my projects</a>
						<a href="mailto:abdurakhmonkuchkorov@gmail.com" class="btn secondary">get in touch</a>
					</div>
				</div>
			</section>

			<section id="projects" class="projects-section">
				<div class="section-header">
					<h3 class="section-title">featured projects</h3>
				</div>
				<div class="projects-grid">
					{projects.map((project) => (
						<div class="project-card">
							<div class="card-content">
								<h4>{project.title}</h4>
								<p>{project.description}</p>
								<div class="tags">
									{project.tags.map(tag => <span class="tag">{tag}</span>)}
								</div>
							</div>
							<div class="card-action">
								<a href={project.link} class="view-project">architecture <span class="arrow">→</span></a>
							</div>
						</div>
					))}
				</div>
				<div class="view-all-container">
					<a href="/projects" class="view-all-link">view all projects <span class="arrow">→</span></a>
				</div>
			</section>
		</main>
		<Footer />
		<Analytics />
	</body>
</html>

<script>
	const tokens = [
		{ char: 'h' }, { char: 'i' }, { char: ',' }, { char: ' ' },
		{ char: 'i' }, { char: ' ' }, { char: 'a' }, { char: 'm' }, { char: ' ' },
		{ char: '{', class: 'brace' }, { char: 'a' }, { char: 'b' }, { char: 'd' }, { char: 'i' },
		{ char: ';', class: 'semi' }, { char: '}', class: 'brace' }
	];
	const target = document.getElementById('typewriter');
	
	let currentIndex = 0;
	function typeWriter() {
		if (target && currentIndex < tokens.length) {
			const token = tokens[currentIndex];
			if (token.class) {
				target.innerHTML += `<span class="${token.class}">${token.char}</span>`;
			} else {
				target.innerHTML += token.char;
			}
			currentIndex++;
			setTimeout(typeWriter, 60);
		}
	}
	
	// Start typing after a short delay
	setTimeout(typeWriter, 250);
</script>

<style>


	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	/* Hero Section */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		min-height: 50vh;
		margin-bottom: 6rem;
		position: relative;
	}

	.hero-content {
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero h1 {
		font-size: 4.5rem;
		font-weight: 800;
		color: #1a202c; /* Ensure explicit dark gray text in light mode */
		margin-bottom: 0.5rem;
		line-height: 1.1;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 1.2em;
	}

	:global(html.dark-theme) .hero h1 #typewriter {
		color: #ffffff;
		background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	:global(span.brace) {
		color: #f97316; /* Orange color for {} in both modes */
		-webkit-text-fill-color: #f97316;
	}

	:global(span.semi) {
		color: #dcdcaa; /* VS Code default function/semi-colon yellow-ish color, or use #3b82f6 if you prefer blue */
		-webkit-text-fill-color: #dcdcaa;
	}

	:global(html.light-theme span.semi), :global(html:not(.dark-theme) span.semi) {
		color: #795e26; /* VS code light theme yellow/brown function color */
		-webkit-text-fill-color: #795e26;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.hero h2 {
		font-size: 1.8rem;
		color: #3b82f6;
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.hero p {
		font-size: 1.2rem;
		color: #4a5568 !important; /* Force explicit legibility in light mode */
		max-width: 600px;
		line-height: 1.6;
		margin-bottom: 2.5rem;
	}

	:global(html.dark-theme) .hero p {
		color: var(--text-muted) !important;
	}

	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	.btn {
		padding: 0.8rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		font-size: 1rem;
	}

	.btn.primary {
		background: var(--accent-glow);
		color: #ffffff; /* Must explicitly be white in both modes to contrast the blue bubble */
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
	}

	.btn.primary:hover {
		background: #1d4ed8;
		box-shadow: 0 0 30px rgba(59, 130, 246, 0.6);
		transform: translateY(-2px);
		color: #ffffff;
	}

	.btn.secondary {
		background: transparent;
		color: #1a202c; /* Light mode text */
		border: 1px solid #cbd5e1;
	}

	:global(html.dark-theme) .btn.secondary {
		color: var(--text-main);
		border-color: var(--card-border);
	}

	.btn.secondary:hover {
		background: rgba(0,0,0,0.05);
		transform: translateY(-2px);
	}

	:global(html.dark-theme) .btn.secondary:hover {
		background: rgba(255,255,255,0.05);
	}



	/* Projects Section */
	.projects-section {
		margin-top: 4rem;
	}

	.section-title {
		font-size: 2rem;
		color: #1a202c; /* light mode */
		margin-bottom: 2rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	:global(html.dark-theme) .section-title {
		color: #fff;
	}

	.section-title::after {
		content: "";
		height: 1px;
		flex: 1;
		background: linear-gradient(90deg, #e2e8f0, transparent);
	}

	:global(html.dark-theme) .section-title::after {
		background: linear-gradient(90deg, var(--card-border), transparent);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.section-header .section-title {
		margin-bottom: 0;
		flex: 1;
	}

	.view-all-container {
		display: flex;
		justify-content: center;
		margin-top: 3rem;
	}

	.view-all-link {
		color: #3b82f6;
		font-weight: 600;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		font-size: 1rem;
		transition: all 0.3s ease;
		padding: 0.5rem 1rem;
		border-radius: 8px;
		background: rgba(59, 130, 246, 0.1);
	}

	.view-all-link:hover {
		background: rgba(59, 130, 246, 0.2);
		transform: translateY(-2px);
	}

	.view-all-link .arrow {
		margin-left: 0.5rem;
		transition: transform 0.3s ease;
	}

	.view-all-link:hover .arrow {
		transform: translateX(4px);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.project-card {
		background: #ffffff; /* Light mode base */
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	:global(html.dark-theme) .project-card {
		background: var(--card-bg);
		border-color: var(--card-border);
		backdrop-filter: blur(10px);
	}

	.project-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: linear-gradient(90deg, #3b82f6, #8b5cf6);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.project-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
		border-color: rgba(59, 130, 246, 0.3);
	}

	:global(html.dark-theme) .project-card:hover {
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
	}

	.project-card:hover::before {
		opacity: 1;
	}

	.project-card h4 {
		font-size: 1.4rem;
		color: #1d4ed8; /* distinct blue for project headers in light mode */
		margin-bottom: 1rem;
	}
	
	:global(html.dark-theme) .project-card h4 {
		color: #fff;
	}

	.project-card p {
		color: #334155; /* explicit dark color for readability */
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
	}

	:global(html.dark-theme) .project-card p {
		color: var(--text-muted);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.tag {
		background: rgba(59, 130, 246, 0.1);
		color: #93c5fd;
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.8rem;
		font-weight: 500;
		border: 1px solid rgba(59, 130, 246, 0.2);
	}

	.card-action {
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid #e2e8f0;
	}

	:global(html.dark-theme) .card-action {
		border-top-color: var(--card-border);
	}

	.view-project {
		color: #1e293b; /* Light mode interaction */
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		display: inline-flex;
		align-items: center;
		transition: color 0.3s ease;
	}

	:global(html.dark-theme) .view-project {
		color: #fff;
	}

	.view-project .arrow {
		margin-left: 0.5rem;
		transition: transform 0.3s ease;
	}

	.view-project:hover {
		color: var(--accent-glow);
	}

	.view-project:hover .arrow {
		transform: translateX(5px);
	}

	@media (max-width: 768px) {
		main {
			padding: 2rem 1.25rem;
			width: 100%;
			box-sizing: border-box;
		}
		.hero {
			flex-direction: column;
			text-align: center;
			margin-bottom: 3rem;
			min-height: auto;
			padding-top: 2rem;
			width: 100%;
		}
		.hero-actions {
			flex-direction: column;
			gap: 0.75rem;
			width: 100%;
			max-width: 260px; /* Slightly narrower for better fit */
			margin: 0 auto; /* CENTER the buttons */
		}
		.btn {
			width: 100%;
			text-align: center;
			padding: 0.8rem 1.2rem;
			box-sizing: border-box;
		}
		.hero-graphic {
			display: none;
		}
		.hero h1 {
			font-size: 2.2rem;
			word-break: break-word;
			padding: 0 0.5rem;
		}
		.hero h2 {
			font-size: 1.3rem;
			padding: 0 1rem;
		}
		.hero p {
			font-size: 1rem;
			padding: 0 1.5rem;
		}
		.projects-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 0 0.5rem; /* Space on sides of cards */
		}
		.project-card {
			padding: 1.5rem;
			width: 100%;
			box-sizing: border-box;
		}
	}
</style>
