---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const SITE_TITLE = "projects | abdi";
const SITE_DESCRIPTION = "all automation projects and system architectures by abdi.";

// Fetching all projects if you use collections, or hardcode them here.
// Assuming we are just using the same array for now
const projects = [
	{
		title: "Active Suspension System",
		description: "design and implementation of a robust industrial control loop for automated processes.",
		tags: ["plc", "scada", "control systems"],
		link: "/blog/industrial-control-loop"
	},
	{
		title: "HIL Drive-by-Wire",
		description: "hardware-in-the-loop simulation for a drive-by-wire automotive system.",
		tags: ["hil", "automotive", "simulink"],
		link: "/blog/hil-drive-by-wire"
	}
	// Add more projects here
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="">
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">projects</h1>
				<p class="page-description">a complete archive of my automation projects, hardware designs, and system architectures.</p>
			</div>

			<div class="projects-grid">
				{projects.map((project) => (
					<div class="project-card">
						<div class="card-content">
							<h4>{project.title}</h4>
							<p>{project.description}</p>
							<div class="tags">
								{project.tags.map(tag => <span class="tag">{tag}</span>)}
							</div>
						</div>
						<div class="card-action">
							<a href={project.link} class="view-project">view details <span class="arrow">→</span></a>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Global Smooth Scrolling and Transitions reused from index */
	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body), :global(body *) {
		transition: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
	}

	/* CSS Variables defined for Light Mode (default) */
	:global(body) {
		--bg-color: #ffffff;
		--text-main: #1a202c;
		--text-muted: #4a5568;
		--accent-glow: #2563eb;
		--accent-dark: #1e3a8a;
		--card-bg: #ffffff;
		--card-border: #e2e8f0;
	}

	/* Dark Mode Overrides */
	:global(body.dark-theme) {
		--bg-color: #0f1115;
		--text-main: #e2e8f0;
		--text-muted: #94a3b8;
		--accent-glow: #3b82f6;
		--accent-dark: #1e3a8a;
		--card-bg: rgba(30, 41, 59, 0.7);
		--card-border: rgba(255, 255, 255, 0.1);
		
		background: var(--bg-color);
		color: var(--text-main);
	}

	:global(.dark-theme header) {
		background: rgba(15, 17, 21, 0.8) !important;
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--card-border);
		box-shadow: none !important;
	}
	
	:global(.dark-theme nav a) {
		color: var(--text-main) !important;
	}

	:global(.dark-theme footer) {
		color: var(--text-muted) !important;
		background: var(--bg-color) !important;
	}

	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 2rem;
		min-height: calc(100vh - 200px);
	}

	/* Page Header */
	.page-header {
		margin-bottom: 4rem;
		text-align: center;
	}

	.page-title {
		font-size: 3.5rem;
		font-weight: 800;
		color: #1a202c; /* Ensure explicit dark gray text in light mode */
		margin-bottom: 1rem;
		line-height: 1.1;
	}

	:global(body.dark-theme) .page-title {
		color: #ffffff;
	}

	.page-description {
		font-size: 1.2rem;
		color: #4a5568 !important; /* Force explicit legibility in light mode */
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}

	:global(body.dark-theme) .page-description {
		color: var(--text-muted) !important;
	}

	/* Projects Grid - Same styles as homepage */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.project-card {
		background: #ffffff; /* Light mode base */
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	:global(body.dark-theme) .project-card {
		background: var(--card-bg);
		border-color: var(--card-border);
		backdrop-filter: blur(10px);
	}

	.project-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: linear-gradient(90deg, #3b82f6, #8b5cf6);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.project-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
		border-color: rgba(59, 130, 246, 0.3);
	}

	:global(body.dark-theme) .project-card:hover {
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
	}

	.project-card:hover::before {
		opacity: 1;
	}

	.project-card h4 {
		font-size: 1.4rem;
		color: #1d4ed8; /* distinct blue for project headers in light mode */
		margin-bottom: 1rem;
	}
	
	:global(body.dark-theme) .project-card h4 {
		color: #fff;
	}

	.project-card p {
		color: #334155; /* explicit dark color for readability */
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
	}

	:global(body.dark-theme) .project-card p {
		color: var(--text-muted);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.tag {
		background: rgba(59, 130, 246, 0.1);
		color: #93c5fd;
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.8rem;
		font-weight: 500;
		border: 1px solid rgba(59, 130, 246, 0.2);
	}

	.card-action {
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid #e2e8f0;
	}

	:global(body.dark-theme) .card-action {
		border-top-color: var(--card-border);
	}

	.view-project {
		color: #1e293b; /* Light mode interaction */
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		display: inline-flex;
		align-items: center;
		transition: color 0.3s ease;
	}

	:global(body.dark-theme) .view-project {
		color: #fff;
	}

	.view-project .arrow {
		margin-left: 0.5rem;
		transition: transform 0.3s ease;
	}

	.view-project:hover {
		color: var(--accent-glow);
	}

	.view-project:hover .arrow {
		transform: translateX(5px);
	}
</style>
