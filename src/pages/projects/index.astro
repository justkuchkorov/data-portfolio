---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Analytics from '@vercel/analytics/astro';

const SITE_TITLE = "projects | abdi";
const SITE_DESCRIPTION = "all automation projects and system architectures by abdi.";

type Project = {
	title: string;
	description: string;
	tags: string[];
	article?: string;
	github: string;
};

const projects: Project[] = [
	{
		title: "BMS",
		description: "Battery management system with monitoring and fault protection logic.",
		tags: ["embedded", "firmware", "electronics"],
		github: "https://github.com/justkuchkorov/bms/releases/tag/v1.1.0"
	},
	{
		title: "TCS",
		description: "Traction control system with state-machine signal logic.",
		tags: ["control", "automation", "embedded"],
		github: "https://github.com/justkuchkorov/tcs/releases/tag/v1.0.0"
	},
	{
		title: "Wortblitz",
		description: "German vocabulary trainer built to prep for masters in Germany.",
		tags: ["web", "language", "learning"],
		github: "https://github.com/justkuchkorov/wortblitz"
	},
	{
		title: "GeminiLens",
		description: "AI-powered vision system for industrial inspection and monitoring.",
		tags: ["ai", "vision", "automation"],
		github: "https://github.com/justkuchkorov"
	},
	{
		title: "Transformer Digital Twin",
		description: "Closed-loop thermal simulation to stress-test industrial PLC safety logic.",
		tags: ["digital twin", "plc", "simulation"],
		article: "/blog/transformer-digital-twin",
		github: "https://github.com/justkuchkorov/transformer_digital_twin"
	},
	{
		title: "Active Suspension HIL",
		description: "Quarter-car physics bridged to CODESYS SoftPLC over Modbus TCP/IP.",
		tags: ["plc", "python", "control systems"],
		article: "/blog/active-suspension",
		github: "https://github.com/justkuchkorov/active-suspension-hil"
	},
	{
		title: "HIL Drive-by-Wire",
		description: "Hardware-in-the-loop simulation for a drive-by-wire automotive system.",
		tags: ["hil", "automotive", "codesys"],
		article: "/blog/hil-drive-by-wire",
		github: "https://github.com/justkuchkorov/HIL-Drive-By-Wire-Sim"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-head">
				<h1>Projects</h1>
				<p>Automation projects, hardware designs, and system architectures.</p>
			</div>

			<div class="projects-list">
				{projects.map((project) => (
					<div class="project-card">
						<div class="card-top">
							<h3>{project.title}</h3>
							<p>{project.description}</p>
							<div class="tags">
								{project.tags.map(tag => <span class="tag">{tag}</span>)}
							</div>
						</div>
						<div class="card-bottom">
							{project.article && <a href={project.article} class="card-link">Article <span>&rarr;</span></a>}
							<a href={project.github} class="card-link secondary" target="_blank" rel="noopener noreferrer">GitHub <span>&rarr;</span></a>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
		<Analytics />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-12) var(--page-pad) var(--space-16);
	}

	.page-head {
		margin-bottom: var(--space-10);
	}

	.page-head h1 {
		margin-bottom: var(--space-2);
	}

	.page-head p {
		font-size: 0.95rem;
		max-width: 440px;
	}

	.projects-list {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-4);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		padding: var(--space-4);
		transition: box-shadow 150ms ease, transform 150ms ease;
	}

	.project-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.card-top h3 {
		margin-bottom: var(--space-2);
		font-size: 0.95rem;
	}

	.card-top p {
		font-size: 0.82rem;
		margin-bottom: var(--space-3);
		line-height: 1.5;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-1);
		margin-bottom: var(--space-4);
	}

	.tag {
		font-family: var(--mono);
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.15rem 0.4rem;
		border-radius: var(--radius-pill);
		background: var(--accent-muted);
		color: var(--accent);
	}

	.card-bottom {
		display: flex;
		gap: var(--space-4);
		padding-top: var(--space-3);
		border-top: 1px solid var(--line);
	}

	.card-link {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	.card-link.secondary {
		color: var(--text-muted);
	}

	.card-link:hover {
		text-decoration: none;
	}

	.card-link span {
		transition: transform 150ms ease;
	}

	.card-link:hover span {
		transform: translateX(3px);
	}

	@media (max-width: 900px) {
		.projects-list {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 520px) {
		.projects-list {
			grid-template-columns: 1fr;
		}
	}
</style>
